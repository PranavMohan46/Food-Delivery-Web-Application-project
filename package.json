{
  "name": "clover-food-delivery",
  "version": "1.0.0",
  "description": "Food delivery web app — Express API + React frontend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "client:dev": "vite --config client/vite.config.js",
    "client:build": "vite build --config client/vite.config.js",
    "build": "npm run client:build",
    "dev:full": "concurrently \"npm run dev\" \"npm run client:dev\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "razorpay": "^2.9.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^7.1.3"
  }
}
